# Copy to .env and adjust as needed
LDAP_NAMESPACE="sasldap"
LDAP_APP_LABEL="app=sas-ldap-server"
LDAP_SERVICE_NAME="sas-ldap-service"
LDAP_HOST="localhost"
LDAP_PORT="1389"
LDAP_BASE_DN="dc=sasldap,dc=com"
LDAP_USERS_OU="ou=users"
LDAP_GROUPS_OU="ou=groups"
LDAP_ADMIN_DN="cn=admin,dc=sasldap,dc=com"
LDAP_ADMIN_PASSWORD="change-me"

DEFAULT_MAIL_DOMAIN="sasldap.com"
DEFAULT_HOME_PREFIX="/home"
DEFAULT_LOGIN_SHELL="/bin/bash"
DEFAULT_ORGANIZATION="SAS Institute"
DEFAULT_LOCALITY="Italy"
DEFAULT_PASSWORD_LENGTH="18"
DEFAULT_UID_START="7000"
DEFAULT_GID_START="6000"

GENERATED_DIR="generated"
DIRECTORY_FILE="directory.yaml"
